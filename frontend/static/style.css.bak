:root {
  --bg: #f3f6fb;
  --panel: #ffffff;
  --line: #d8e0ea;
  --text: #1e293b;
  --muted: #64748b;
  --brand: #0f3d91;
  --brand-2: #1d4ed8;
}
* { box-sizing: border-box; }
body {
  margin: 0;
  font-family: Arial, Helvetica, sans-serif;
  background: var(--bg);
  color: var(--text);
}
.topbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16px;
  padding: 16px 20px;
  background: #0f172a;
  color: #fff;
}
.topbar h1 { margin: 0; font-size: 22px; }
.subtitle { color: #cbd5e1; font-size: 13px; margin-top: 4px; }
.right-tools { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
.tabs {
  display: flex;
  gap: 8px;
  padding: 12px 16px 0;
}
.tab {
  background: #dbe5f3;
  border: none;
  padding: 10px 14px;
  border-radius: 10px 10px 0 0;
  cursor: pointer;
}
.tab.active { background: var(--panel); font-weight: 700; }
.page { padding: 0 16px 16px; }
.tab-panel { display: none; }
.tab-panel.active { display: block; }
.toolbar { display: flex; gap: 8px; padding: 12px 0; }
.cards {
  display: grid;
  grid-template-columns: repeat(6, minmax(0, 1fr));
  gap: 12px;
  margin-bottom: 16px;
}
.card, .panel {
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 14px;
  box-shadow: 0 2px 8px rgba(15, 23, 42, 0.05);
}
.card { padding: 14px; }
.card .label { color: var(--muted); font-size: 12px; }
.card .value { margin-top: 6px; font-size: 24px; font-weight: 700; }
.panel { padding: 14px; margin-bottom: 16px; }
.grid.two-col {
  display: grid;
  grid-template-columns: 1.15fr 1fr;
  gap: 16px;
}
#map { height: 420px; border-radius: 12px; }
button {
  border: none;
  border-radius: 8px;
  background: var(--brand-2);
  color: #fff;
  padding: 10px 12px;
  cursor: pointer;
}
button.secondary { background: #e2e8f0; color: var(--text); }
button.ghost { background: transparent; color: var(--brand-2); border: 1px solid var(--line); }
input, select {
  width: 100%;
  padding: 10px;
  border-radius: 8px;
  border: 1px solid var(--line);
  background: white;
}
.stack-form { display: grid; gap: 8px; }
.pill {
  background: rgba(255,255,255,0.12);
  border: 1px solid rgba(255,255,255,0.18);
  padding: 8px 10px;
  border-radius: 999px;
  font-size: 12px;
}
.help-box {
  background: #f8fafc;
  border: 1px dashed var(--line);
  border-radius: 10px;
  padding: 10px;
  margin-top: 12px;
  color: var(--muted);
}
.panel-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 8px;
}
.muted { color: var(--muted); }
.error { color: #b91c1c; margin-top: 8px; min-height: 20px; }
.overlay {
  position: fixed;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(15,23,42,0.45);
  z-index: 20;
}
.overlay.hidden { display: none; }
.login-card {
  width: min(380px, 92vw);
  background: white;
  border-radius: 16px;
  padding: 22px;
  box-shadow: 0 10px 30px rgba(0,0,0,0.16);
}
table { width: 100%; border-collapse: collapse; margin-top: 10px; }
th, td { border-bottom: 1px solid #e5e7eb; padding: 8px; text-align: left; vertical-align: top; }
tbody tr:hover { background: #f8fafc; }
.small-table { font-size: 13px; }
.kv-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
.kv-item { background: #f8fafc; border-radius: 10px; padding: 10px; }
.kv-item .k { color: var(--muted); font-size: 12px; }
.kv-item .v { font-size: 20px; font-weight: 700; margin-top: 4px; }
@media (max-width: 1080px) {
  .cards { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  .grid.two-col { grid-template-columns: 1fr; }
}
@media (max-width: 720px) {
  .cards { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  .topbar { flex-direction: column; align-items: flex-start; }
}
